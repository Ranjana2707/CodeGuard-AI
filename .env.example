# ============================================================
# CodeGuard AI — Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit the actual .env file to version control
# ============================================================

# ── Database ──────────────────────────────────────────────
POSTGRES_DB=codeguard
POSTGRES_USER=codeguard
POSTGRES_PASSWORD=change_me_strong_password_here

# ── JWT ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_A_RANDOM_SECRET_KEY_MINIMUM_256_BITS_LONG

# ── AI Provider ───────────────────────────────────────────
# Get from: https://console.anthropic.com/
AI_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_ANTHROPIC_KEY
AI_MODEL=claude-sonnet-4-20250514
AI_PROVIDER=anthropic

# ── GitHub OAuth (optional) ───────────────────────────────
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Frontend (Vite build) ─────────────────────────────────
VITE_API_URL=/api

# ── Production overrides ──────────────────────────────────
# Uncomment and set for production deployment
# SPRING_PROFILES_ACTIVE=prod
# FRONTEND_URL=https://your-domain.com
